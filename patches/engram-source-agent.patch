+func TestHandleSavePersistsSourceAgent(t *testing.T) {
+	s := newMCPTestStore(t)
+	h := handleSave(s, MCPConfig{}, NewSessionActivity(10*time.Minute))
+
+	res, err := h(context.Background(), mcppkg.CallToolRequest{Params: mcppkg.CallToolParams{Arguments: map[string]any{
+		"title":        "React pattern",
+		"content":      "**What**: Stored a reusable React pattern\n**Why**: Useful later\n**Where**: mem-tech-react\n**Learned**: Reuse source metadata",
+		"type":         "pattern",
+		"project":      "mem-tech-react",
+		"scope":        "personal",
+		"topic_key":    "pattern/react-reuse",
+		"source_agent": "frontend-web-developer",
+	}}})
+	if err != nil {
+		t.Fatalf("save handler error: %v", err)
+	}
+	if res.IsError {
+		t.Fatalf("unexpected save error: %s", callResultText(t, res))
+	}
+
+	obs, err := s.RecentObservations("mem-tech-react", "personal", 5)
+	if err != nil {
+		t.Fatalf("recent observations: %v", err)
+	}
+	if len(obs) != 1 {
+		t.Fatalf("expected one observation, got %d", len(obs))
+	}
+	if obs[0].ToolName == nil || *obs[0].ToolName != "agent:frontend-web-developer" {
+		t.Fatalf("expected source agent tool name, got %+v", obs[0].ToolName)
+	}
+}
