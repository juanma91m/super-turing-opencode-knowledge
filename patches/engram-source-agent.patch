+func normalizeSourceAgent(sourceAgent string) string {
+	sourceAgent = strings.TrimSpace(sourceAgent)
+	if sourceAgent == "" {
+		return ""
+	}
+	if strings.HasPrefix(sourceAgent, "agent:") {
+		return sourceAgent
+	}
+	return "agent:" + sourceAgent
+}
+
+func sourceAgentLabel(toolName *string) string {
+	if toolName == nil {
+		return ""
+	}
+	raw := strings.TrimSpace(*toolName)
+	if raw == "" || !strings.HasPrefix(raw, "agent:") {
+		return ""
+	}
+	return strings.TrimPrefix(raw, "agent:")
+}
